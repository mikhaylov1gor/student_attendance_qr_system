# HTTP-сервер
HTTP_PORT=8080
APP_VERSION=dev

# Логирование
LOG_LEVEL=debug
LOG_FORMAT=text

# БД (используется с этапа 2)
DATABASE_DSN=postgres://attendance:attendance@localhost:5432/attendance?sslmode=disable

# JWT (access токен — HS256; refresh — random, хранится как SHA-256 хэш)
# Сгенерировать: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_base64_48bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=attendance-api

# Шифрование ФИО (используется с этапа 4)
# Сгенерировать: openssl rand -base64 32
PII_ENCRYPTION_KEY=change_me_base64_32bytes

# Argon2id параметры (OWASP 2024 baseline)
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# CORS (используется с этапа 13)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
